{
    "$meshes": [
        "meshes/CornellBox.obj"
    ],
    "$materials": {
        "LeftWall":  { "$type": "Diffuse", "$color": [1.0, 0.0, 0.0] },
        "RightWall": { "$type": "Diffuse", "$color": [0.0, 1.0, 0.0] },
        "Wall":      { "$type": "Diffuse", "$color": [1.0] },
        "BallMat":   { "$type": "Diffuse", "$color": [0.2, 0.4, 0.95] }
    },
    "$workerConfiguration": {
        "$workerCount": 32,
        "$fetchSize": 100000,
        "$photonQueueSize": 20000000
    },
    "$renderConfiguration": {
        "$width": 256,
        "$height": 256,
        "$photonsPerLight": 4000000,
        "$startFrame": 0,
        "$endFrame": 0,
        "$frameRate": 8.0,
        "$shutterTime": 0.0,
        "$cameraTimeSamples": 1,
        "$frameOffset": 0.5,
        "$renderPath": "/tmp/cammb",
        "$renderName": "cam_translate_static",
        "$bounceThreshold": 2
    },
    "$scene": {
        "Camera": {
            "$type": "Camera",
            "$verticalFieldOfView": 90.0,
            "$position": [0.0, 150, -300],
            "$rotation": { "$type": "PitchYawRollDegrees", "$value": [0.0, 0.0, 0.0] },
            "$animation": {
                "$position": [
                    { "t": 0.0, "value": [-160.0, 150.0, -300.0] },
                    { "t": 1.0, "value": [ 160.0, 150.0, -300.0] }
                ]
            }
        },
        "Light": {
            "$type": "AreaLight",
            "$shape": "Square",
            "$size": 120,
            "$position": [0, 298, 0],
            "$rotation": { "$type": "PitchYawRollDegrees", "$value": [90, 0, 0] },
            "$color": [1.0, 1.0, 1.0],
            "$luminousFlux": 125663706
        },
        "Ball": {
            "$type": "SphereVolume",
            "$material": "BallMat",
            "$center": [0, 60, 60],
            "$radius": 60
        },
        "CornellBox": {
            "$type": "Object",
            "Ceiling":   { "$type": "MeshVolume", "$material": "Wall",      "$mesh": "Ceiling" },
            "LeftWall":  { "$type": "MeshVolume", "$material": "LeftWall",  "$mesh": "Left" },
            "RightWall": { "$type": "MeshVolume", "$material": "RightWall", "$mesh": "Right" },
            "Floor":     { "$type": "MeshVolume", "$material": "Wall",      "$mesh": "Floor" },
            "Back":      { "$type": "MeshVolume", "$material": "Wall",      "$mesh": "Back" }
        }
    }
}
