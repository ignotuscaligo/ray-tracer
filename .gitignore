*.sublime-workspace
.idea/

build/
renders/
CMakeUserPresets.json

# ImGui runtime layout file, written next to the editor binary / CWD.
imgui.ini

# Editor render-from-current-view temp scenes (written next to the source scene
# so relative $meshes / $renderPath still resolve). Regenerated every render.
.editor_view_*
# Editor to-disk multi-camera Render temp scenes. Regenerated every Render.
.editor_render_*

# Python bytecode cache
__pycache__/
*.pyc
